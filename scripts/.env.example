# 💧 Daily Drip Automation Credentials Template
# Copy this file to a new file named '.env' and fill in your values.

# --- Printify Credentials ---
# Generate your personal access token at https://printify.com/app/store/settings/api
PRINTIFY_API_TOKEN=your_printify_personal_access_token_here

# Get your Printify Shop ID. Run the manager tool with the 'test' command to find it.
PRINTIFY_SHOP_ID=your_printify_shop_id_here

# --- Meta Marketing Credentials ---
# Generate a user access token with ads_management and ads_read permissions in Meta App Dashboard
META_ACCESS_TOKEN=your_meta_system_user_access_token_here

# Find your Meta Ad Account ID (typically in business manager or ads manager link, prefix 'act_')
META_AD_ACCOUNT_ID=act_your_ad_account_id_here

# Find your Facebook Page ID associated with the Daily Drip storefront
META_PAGE_ID=your_facebook_page_id_here

# --- Collaborator Notification Settings ---
# Your name (e.g., Nathan or Alby)
SENDER_NAME=Nathan
# Your collaborator's contact info for Apple iMessage (phone number or email address)
COLLABORATOR_CONTACT=+1 (213) 468-9429


